{
  "name": "viscory.github.io",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint:css": "stylelint 'src/**/*.css'",
    "format": "prettier --check 'src/**/*.{astro,css,ts}'",
    "format:fix": "prettier --write 'src/**/*.{astro,css,ts}'",
    "check": "pnpm run lint:css && pnpm run format && pnpm run build"
  },
  "dependencies": {
    "astro": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "stylelint": "^16.0.0"
  }
}
