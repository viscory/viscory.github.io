---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faiyaz Rahman — AI Engineer</title>
    <meta
      name="description"
      content="AI engineer in Hong Kong. Building LLM-powered systems for finance — RAG pipelines, vector search, and quantitative data platforms. Python, TypeScript, AWS Bedrock, Kafka."
    />
    <meta
      name="keywords"
      content="Faiyaz Rahman, AI engineer, Hong Kong, RAG, AWS Bedrock, LLM, vector search, Python, TypeScript"
    />
    <meta name="author" content="Faiyaz Rahman" />
    <meta property="og:title" content="Faiyaz Rahman — AI Engineer" />
    <meta
      property="og:description"
      content="AI engineer in Hong Kong building LLM-powered systems for finance — RAG pipelines, vector search, and quantitative data platforms."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://viscory.github.io" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://viscory.github.io" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link rel="preconnect" href="https://data.weather.gov.hk" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.6.0/remixicon.min.css"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14' font-size='14'>F</text></svg>"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Faiyaz Rahman",
        "url": "https://viscory.github.io",
        "jobTitle": "Full Stack Developer",
        "sameAs": [
          "https://github.com/viscory",
          "https://linkedin.com/in/faiyazr"
        ],
        "email": "faiman.rahyaz@gmail.com",
        "alumniOf": "The Chinese University of Hong Kong",
        "knowsAbout": ["TypeScript", "Python", "Go", "Kafka", "Kubernetes"]
      }
    </script>
    <script
      data-goatcounter="https://viscory.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div id="scroll-progress" aria-hidden="true"></div>
    <canvas id="bg" aria-hidden="true"></canvas>

    <div id="hud">
      <div class="time" id="hud-time" aria-live="polite">--:-- HKT</div>
      <div class="loc"><span id="hud-weather"></span>Hong Kong</div>
    </div>

    <nav class="container nav-bar" aria-label="Section navigation">
      <div class="nav-inner">
        <a href="#" class="nav-brand">Faiyaz Rahman</a>
        <ul class="nav-list">
          <li><a href="#about" class="meta">About</a></li>
          <li><a href="#experience" class="meta">Experience</a></li>
          <li><a href="#skills" class="meta">Skills</a></li>
          <li><a href="#projects" class="meta">Projects</a></li>
          <li><a href="#education" class="meta">Education</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer
      class="container"
      style="border-top: 1px solid var(--color-fg); padding-top: 6px; padding-bottom: 6px; margin-top: 0;"
    >
      <div
        style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem;"
      >
        <span class="meta">&copy; 2026 Faiyaz Rahman</span>
        <span class="meta" style="letter-spacing: 0.05em;">Hong Kong</span>
      </div>
    </footer>

    <script src="../scripts/interactive.ts"></script>
  </body>
</html>
