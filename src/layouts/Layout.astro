---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faiyaz Rahman — Full Stack Developer</title>
    <meta
      name="description"
      content="Full-stack developer based in Hong Kong. 5+ years building systems across AI, infrastructure, and product. TypeScript, Python, Go, Kafka, Kubernetes, AWS Bedrock."
    />
    <meta
      name="keywords"
      content="Faiyaz Rahman, full stack developer, Hong Kong, TypeScript, Python, Kafka, Kubernetes, Premialab"
    />
    <meta name="author" content="Faiyaz Rahman" />
    <meta property="og:title" content="Faiyaz Rahman — Full Stack Developer" />
    <meta
      property="og:description"
      content="Full-stack developer based in Hong Kong. Building event-driven data platforms at scale."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://viscory.github.io" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://viscory.github.io" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.9.1/remixicon.min.css"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14' font-size='14'>F</text></svg>"
    />
  </head>
  <body>
    <canvas id="bg" aria-hidden="true"></canvas>

    <div id="hud">
      <div class="time" id="hud-time" aria-live="polite">--:-- HKT</div>
      <div class="loc">Hong Kong</div>
    </div>

    <nav class="container nav-bar" aria-label="Section navigation">
      <ul class="nav-list">
        <li><a href="#about" class="meta">About</a></li>
        <li><a href="#experience" class="meta">Experience</a></li>
        <li><a href="#skills" class="meta">Skills</a></li>
        <li><a href="#projects" class="meta">Projects</a></li>
        <li><a href="#education" class="meta">Education</a></li>
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer
      class="container"
      style="border-top: 1px solid var(--color-fg); padding: var(--space-inner) 24px 2rem; margin-top: 0;"
    >
      <div
        style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem;"
      >
        <span class="meta">&copy; Faiyaz Rahman</span>
        <span class="meta" style="letter-spacing: 0.05em;">Hong Kong</span>
      </div>
    </footer>

    <script src="../scripts/interactive.ts"></script>
  </body>
</html>
