---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const MONTHS = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];
function parseDate(s: string): number {
  if (s === "Present") return 999999;
  const [m, y] = s.split(" ");
  return parseInt(y) * 12 + MONTHS.indexOf(m);
}

const experience = (await getCollection("experience")).sort(
  (a, b) => parseDate(b.data.endDate) - parseDate(a.data.endDate),
);

const projects = (await getCollection("projects")).sort(
  (a, b) => parseInt(b.data.startYear) - parseInt(a.data.startYear),
);

const skills = [
  "TypeScript",
  "Python",
  "Java",
  "Scala",
  "Kotlin",
  "Go",
  "SQL",
  "Vue.js",
  "React",
  "Nest.js",
  "Spring",
  "Ktor",
  "Flask",
  "FastAPI",
  "AWS",
  "Alibaba Cloud",
  "Docker",
  "Kubernetes",
  "ArgoCD",
  "Kafka",
  "PostgreSQL",
  "MongoDB",
  "Redis",
  "Elasticsearch",
  "Terraform",
  "Helm",
  "AWS Bedrock",
  "RAG",
  "Vector DBs",
  "GitOps",
  "CI/CD",
  "Microservices",
  "Event-Driven",
  "CQRS",
];

const projectIcons: Record<string, string> = {
  Homelab:
    '<svg viewBox="0 0 24 24" fill="currentColor" style="width:28px;height:28px;flex-shrink:0;opacity:.6"><path d="M21 6.76V19a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6.76l9-5.5 9 5.5zM8 12h8v7H8v-7z" fill="currentColor"/><path d="M11 5h2v2h-2z" fill="currentColor" opacity=".4"/></svg>',
  "paperless-py":
    '<svg viewBox="0 0 24 24" fill="currentColor" style="width:28px;height:28px;flex-shrink:0;opacity:.6"><path d="M4 4a2 2 0 0 1 2-2h8l6 6v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4z"/><path d="M8 11h8v2H8zm0 4h5v2H8z" fill="currentColor" opacity=".6"/></svg>',
  reciprocus:
    '<svg viewBox="0 0 24 24" fill="currentColor" style="width:28px;height:28px;flex-shrink:0;opacity:.6"><path d="M18.36 5.64a5 5 0 0 1 0 7.07l-2.83 2.83a5 5 0 0 1-7.07 0 5 5 0 0 1 0-7.07l1.42 1.42a3 3 0 0 0 0 4.24 3 3 0 0 0 4.24 0l2.83-2.83a3 3 0 0 0 0-4.24 3 3 0 0 0-4.24 0L9.88 7.05a5 5 0 0 1 7.07 0l1.41 1.41z" fill="currentColor"/><path d="M5.64 18.36a5 5 0 0 1 0-7.07l2.83-2.83a5 5 0 0 1 7.07 0 5 5 0 0 1 0 7.07l-1.42-1.42a3 3 0 0 0 0-4.24 3 3 0 0 0-4.24 0L7.05 14.7a3 3 0 0 0 0 4.24 3 3 0 0 0 4.24 0l1.41 1.41a5 5 0 0 1-7.07 0z" fill="currentColor" opacity=".6"/></svg>',
  chirper:
    '<svg viewBox="0 0 24 24" fill="currentColor" style="width:28px;height:28px;flex-shrink:0;opacity:.6"><path d="M22 4.01c-.9.4-1.8.67-2.7.8a4.7 4.7 0 0 0 2.07-2.6 9.3 9.3 0 0 1-2.98 1.14 4.68 4.68 0 0 0-7.97 4.27A13.3 13.3 0 0 1 3.2 2.9a4.68 4.68 0 0 0 1.45 6.24c-.74 0-1.48-.2-2.1-.54v.06a4.68 4.68 0 0 0 3.75 4.59c-.7.19-1.43.21-2.14.08a4.69 4.69 0 0 0 4.37 3.25A9.42 9.42 0 0 1 2 19.54a13.3 13.3 0 0 0 7.2 2.1c8.64 0 13.36-7.16 13.36-13.36 0-.2 0-.4-.02-.6A9.6 9.6 0 0 0 22 4.01z"/></svg>',
  default:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" style="width:28px;height:28px;flex-shrink:0;opacity:.6"><circle cx="12" cy="12" r="9" stroke-width="2"/></svg>',
};
---

<Layout>
  <!-- HERO -->
  <section
    id="hero"
    class="container"
    style="padding: var(--space-section) 24px 0;"
  >
    <div style="max-width: 480px;">
      <img
        src="/assets/headshot.jpg"
        alt=""
        width="80"
        height="80"
        style="border-radius: 50%; filter: grayscale(1); margin-bottom: 2rem;"
      />
      <h1>Faiyaz<br />Rahman</h1>
      <p style="margin: 1.5rem 0 2rem; max-width: 420px;">
        Full-stack developer building systems across AI, infrastructure, and
        product.
      </p>
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a
          href="mailto:faiman.rahyaz@gmail.com"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px;"
          ><svg
            viewBox="0 0 24 24"
            fill="currentColor"
            style="width:14px;height:14px"
            ><path
              d="M3 3h18a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm17 4.238l-7.928 7.1L4 7.216V19h16V7.238zM4.511 5l7.55 6.662L19.502 5H4.511z"
            ></path></svg
          >Email</a
        >
        <a
          href="https://github.com/viscory"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px;"
          target="_blank"
          rel="noopener"
          ><svg
            viewBox="0 0 24 24"
            fill="currentColor"
            style="width:14px;height:14px"
            ><path
              d="M12 2C6.475 2 2 6.475 2 12a9.994 9.994 0 0 0 6.838 9.488c.5.087.687-.213.687-.476 0-.237-.013-1.024-.013-1.862-2.782.613-3.369-1.188-3.369-1.188-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.577.688.476A10.016 10.016 0 0 0 22 12c0-5.525-4.475-10-10-10z"
            ></path></svg
          >GitHub</a
        >
        <a
          href="https://linkedin.com/in/faiyazr"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px;"
          target="_blank"
          rel="noopener"
          ><svg
            viewBox="0 0 24 24"
            fill="currentColor"
            style="width:14px;height:14px"
            ><path
              d="M18.335 18.339H15.67v-4.177c0-.996-.02-2.278-1.39-2.278-1.389 0-1.601 1.084-1.601 2.205v4.25h-2.666V9.75h2.56v1.17h.035c.358-.674 1.228-1.387 2.528-1.387 2.7 0 3.2 1.778 3.2 4.091v4.715zM7.003 8.575a1.546 1.546 0 0 1-1.548-1.549 1.548 1.548 0 1 1 1.547 1.549zm1.336 9.764H5.666V9.75H8.34v8.589zM19.67 3H4.33C3.594 3 3 3.58 3 4.297v15.406C3 20.42 3.594 21 4.328 21h15.338C20.4 21 21 20.42 21 19.703V4.297C21 3.58 20.4 3 19.666 3h.003z"
            ></path></svg
          >LinkedIn</a
        >
        <a
          href="/assets/resume.pdf"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px;"
          target="_blank"
          rel="noopener"
          ><svg
            viewBox="0 0 24 24"
            fill="currentColor"
            style="width:14px;height:14px"
            ><path
              d="M21 2.992v18.016a1 1 0 0 1-.993.992H3.993A.993.993 0 0 1 3 21.008V2.992A1 1 0 0 1 3.993 2h16.014c.548 0 .993.444.993.992zM19 4H5v16h14V4zm-7 4h3v2h-3V8zm0 4h5v2h-5v-2zm0 4h-4v2h4v-2zM8 8h2v2H8V8z"
            ></path></svg
          >Resume</a
        >
      </div>
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- ABOUT -->
  <section
    id="about"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <span class="meta" style="display: block; margin-bottom: 1.5rem;"
      >About</span
    >
    <p>
      Full-stack developer with 5+ years delivering systems across AI,
      infrastructure, and product. Architected multi-cloud fintech platforms,
      scaled Kafka to 1.5M+ messages/day, built Bedrock/RAG pipelines for
      quantitative reporting. Comfortable in TypeScript APIs, Vue/React UIs, and
      the GitOps glue between them.
    </p>
  </section>

  <hr class="container section-divider" />

  <!-- EXPERIENCE -->
  <section
    id="experience"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <span class="meta" style="display: block; margin-bottom: 1.5rem;"
      >Experience</span
    >
    <div class="bordered" style="border-top: none;">
      {
        experience.map((entry) => (
          <div class="bordered-bottom" style="padding: 1.25rem 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.25rem;">
              <h3>{entry.data.company}</h3>
              <span class="meta">
                {entry.data.startDate} &ndash; {entry.data.endDate}
              </span>
            </div>
            <span class="meta" style="display: block; margin-bottom: 0.75rem;">
              {entry.data.role} &middot; {entry.data.location}
            </span>
            <ul style="list-style: none; padding: 0;">
              {entry.body
                .split("\n")
                .filter((l) => l.trim().startsWith("-"))
                .map((line) => (
                  <li style="padding: 0.2rem 0; text-indent: -1.1rem; padding-left: 1.1rem;">
                    &mdash;&nbsp;{line.trim().replace(/^-\s*/, "")}
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- SKILLS -->
  <section
    id="skills"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <span class="meta" style="display: block; margin-bottom: 1.5rem;"
      >Skills</span
    >
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {
        skills.map((skill) => (
          <span
            class="btn"
            style="padding: 0.3em 0.8em; font-size: var(--text-meta); text-transform: uppercase;"
          >
            {skill}
          </span>
        ))
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- PROJECTS -->
  <section
    id="projects"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <span class="meta" style="display: block; margin-bottom: 1.5rem;"
      >Projects</span
    >
    <div class="bordered" style="border-top: none;">
      {
        projects.map((project, i) => {
          const icon = projectIcons[project.data.title] || projectIcons.default;
          return (
            <div
              class={i < projects.length - 1 ? "bordered-bottom" : ""}
              style="padding: 1.25rem 1rem;"
            >
              <div style="display: flex; gap: 1rem; align-items: flex-start;">
                <span set:html={icon} />
                <div>
                  <h3>{project.data.title}</h3>
                  <span
                    class="meta"
                    style="display: block; margin: 0.25rem 0 0.75rem;"
                  >
                    {project.data.startYear}
                    {project.data.endYear ? ` – ${project.data.endYear}` : ""}
                  </span>
                  <p style="margin-bottom: 0.75rem;">{project.body}</p>
                  <a href={project.data.url} target="_blank" rel="noopener">
                    GitHub
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- EDUCATION -->
  <section
    id="education"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <span class="meta" style="display: block; margin-bottom: 1.5rem;"
      >Education</span
    >
    <div
      class="bordered"
      style="padding: 1.5rem 1.25rem; display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap;"
    >
      <img
        src="/assets/school-logo-1x.png"
        alt="CUHK"
        width="80"
        style="filter: grayscale(1); flex-shrink: 0;"
      />
      <div>
        <h3>The Chinese University of Hong Kong</h3>
        <p>
          B.Sc. in Computer Science &middot; Second Class Honours (2:1) &middot;
          Sep 2018 &ndash; Jun 2023
        </p>
        <div style="margin-top: 0.5rem;">
          <span class="meta" style="display: block;"
            >Concentration: Database and Information Systems</span
          >
          <span class="meta" style="display: block;"
            >Full Ride Admission Scholarship &middot; The 'Sunny' Award</span
          >
          <span class="meta" style="display: block;"
            >English Debating Team &middot; Google Developers Student Club</span
          >
        </div>
      </div>
    </div>
  </section>

  <div style="height: 4rem;"></div>

  <!-- FSM Mood Button -->
  <button id="chat-btn" aria-label="Mood"
    ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
      ><circle cx="12" cy="12" r="9"></circle></svg
    ></button
  >
</Layout>
