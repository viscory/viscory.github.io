---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const MONTHS = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];
function parseDate(s: string): number {
  if (s === "Present") return 999999;
  const [m, y] = s.split(" ");
  return parseInt(y) * 12 + MONTHS.indexOf(m);
}

const experience = (await getCollection("experience")).sort(
  (a, b) => parseDate(b.data.endDate) - parseDate(a.data.endDate),
);

const projects = (await getCollection("projects")).sort(
  (a, b) => parseInt(b.data.startYear) - parseInt(a.data.startYear),
);

const renderedProjects = await Promise.all(
  projects.map(async (p) => ({ entry: p, Content: (await render(p)).Content })),
);

const skills = [
  "TypeScript",
  "Python",
  "Java",
  "Scala",
  "Kotlin",
  "Go",
  "SQL",
  "Vue.js",
  "React",
  "Nest.js",
  "Spring",
  "Ktor",
  "Flask",
  "FastAPI",
  "AWS",
  "Alibaba Cloud",
  "Docker",
  "Kubernetes",
  "ArgoCD",
  "Kafka",
  "PostgreSQL",
  "MongoDB",
  "Redis",
  "Elasticsearch",
  "Terraform",
  "Helm",
  "AWS Bedrock",
  "RAG",
  "Vector DBs",
  "GitOps",
  "CI/CD",
  "Microservices",
  "Event-Driven",
  "CQRS",
];

const projectIcons: Record<string, string> = {
  Homelab: "ri-home-5-line",
  "paperless-py": "ri-file-search-line",
  reciprocus: "ri-bit-coin-line",
  chirper: "ri-twitter-x-line",
  default: "ri-code-line",
};
---

<Layout>
  <!-- HERO -->
  <section
    id="hero"
    class="container"
    style="padding: var(--space-section) 24px 0;"
  >
    <div style="max-width: 480px;">
      <img
        src="/assets/headshot.jpg"
        alt="Faiyaz Rahman"
        width="80"
        height="80"
        loading="lazy"
        decoding="async"
        style="border-radius: 50%; filter: grayscale(1); margin-bottom: 2rem;"
      />
      <h1>Faiyaz<br />Rahman</h1>
      <p style="margin: 1.5rem 0 2rem; max-width: 420px;">
        Full-stack developer building systems across AI, infrastructure, and
        product.
      </p>
      <div
        style="display: flex; gap: 0.75rem; flex-wrap: wrap; padding-bottom: 0.5rem;"
      >
        <a
          href="mailto:faiman.rahyaz@gmail.com"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none;"
          ><i class="ri-mail-line" style="font-size:14px"></i>Email</a
        >
        <a
          href="https://github.com/viscory"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none;"
          target="_blank"
          rel="noopener"
          ><i class="ri-github-line" style="font-size:14px"></i>GitHub</a
        >
        <a
          href="https://linkedin.com/in/faiyazr"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none;"
          target="_blank"
          rel="noopener"
          ><i class="ri-linkedin-line" style="font-size:14px"></i>LinkedIn</a
        >
        <a
          href="/assets/resume.pdf"
          class="btn"
          style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none;"
          target="_blank"
          rel="noopener"
          ><i class="ri-file-text-line" style="font-size:14px"></i>Resume</a
        >
      </div>
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- ABOUT -->
  <section
    id="about"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">About</h2>
    <p>
      Full-stack developer with 5+ years delivering systems across AI,
      infrastructure, and product. Architected multi-cloud fintech platforms,
      scaled Kafka to 1.5M+ messages/day, built Bedrock/RAG pipelines for
      quantitative reporting. Comfortable in TypeScript APIs, Vue/React UIs, and
      the GitOps glue between them.
    </p>
  </section>

  <hr class="container section-divider" />

  <!-- EXPERIENCE -->
  <section
    id="experience"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Experience</h2>
    <div class="bordered" style="border-top: none;">
      {
        experience.map((entry) => (
          <div class="bordered-bottom" style="padding: 1.25rem 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.25rem;">
              <h3>{entry.data.company}</h3>
              <span class="meta">
                {entry.data.startDate} &ndash; {entry.data.endDate}
              </span>
            </div>
            <span class="meta" style="display: block; margin-bottom: 0.75rem;">
              {entry.data.role} &middot; {entry.data.location}
            </span>
            <ul style="list-style: none; padding: 0;">
              {entry.body
                .split("\n")
                .filter((l) => l.trim().startsWith("-"))
                .map((line) => (
                  <li style="padding: 0.2rem 0; text-indent: -1.1rem; padding-left: 1.1rem;">
                    &mdash;&nbsp;{line.trim().replace(/^-\s*/, "")}
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- SKILLS -->
  <section
    id="skills"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Skills</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {skills.map((skill) => <span class="skill-tag">{skill}</span>)}
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- PROJECTS -->
  <section
    id="projects"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Projects</h2>
    <div class="bordered" style="border-top: none;">
      {
        renderedProjects.map(({ entry, Content }, i) => {
          const icon = projectIcons[entry.data.title] || projectIcons.default;
          return (
            <div
              class={i < renderedProjects.length - 1 ? "bordered-bottom" : ""}
              style="padding: 1.25rem 1rem;"
            >
              <div style="display: flex; gap: 1rem; align-items: flex-start;">
                <i
                  class={icon}
                  style="font-size:28px;flex-shrink:0;opacity:.6;line-height:1"
                />
                <div>
                  <h3>{entry.data.title}</h3>
                  <span
                    class="meta"
                    style="display: block; margin: 0.25rem 0 0.75rem;"
                  >
                    {entry.data.startYear}
                    {entry.data.endYear ? ` – ${entry.data.endYear}` : ""}
                  </span>
                  <Content />
                  <a href={entry.data.url} target="_blank" rel="noopener">
                    GitHub
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- EDUCATION -->
  <section
    id="education"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Education</h2>
    <div
      class="bordered"
      style="padding: 1.5rem 1.25rem; display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap;"
    >
      <img
        src="/assets/school-logo-1x.png"
        alt="CUHK"
        width="80"
        style="filter: grayscale(1); flex-shrink: 0;"
      />
      <div>
        <h3>The Chinese University of Hong Kong</h3>
        <p>
          B.Sc. in Computer Science &middot; Second Class Honours (2:1) &middot;
          Sep 2018 &ndash; Jun 2023
        </p>
        <div style="margin-top: 0.5rem;">
          <span class="meta" style="display: block;"
            >Concentration: Database and Information Systems</span
          >
          <span class="meta" style="display: block;"
            >Full Ride Admission Scholarship &middot; The 'Sunny' Award</span
          >
          <span class="meta" style="display: block;"
            >English Debating Team &middot; Google Developers Student Club</span
          >
        </div>
      </div>
    </div>
  </section>

  <div style="height: 4rem;"></div>

  <!-- FSM Mood Button -->
  <button id="chat-btn" aria-label="Mood"
    ><i class="ri-question-line"></i></button
  >
</Layout>
