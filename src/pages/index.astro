---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const MONTHS = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];
function parseDate(s: string): number {
  if (s === "Present") return 999999;
  const [m, y] = s.split(" ");
  return parseInt(y) * 12 + MONTHS.indexOf(m);
}

const experience = (await getCollection("experience")).sort(
  (a, b) => parseDate(b.data.endDate) - parseDate(a.data.endDate),
);

const projects = (await getCollection("projects")).sort(
  (a, b) => parseInt(b.data.startYear) - parseInt(a.data.startYear),
);

const renderedProjects = await Promise.all(
  projects.map(async (p) => ({ entry: p, Content: (await render(p)).Content })),
);

const renderedExperience = await Promise.all(
  experience.map(async (e) => ({
    entry: e,
    Content: (await render(e)).Content,
  })),
);

const skills = [
  "AWS Bedrock",
  "RAG",
  "Vector DBs",
  "Python",
  "TypeScript",
  "Go",
  "Java",
  "Scala",
  "Kotlin",
  "React",
  "Vue.js",
  "FastAPI",
  "Nest.js",
  "Kafka",
  "PostgreSQL",
  "MongoDB",
  "Redis",
  "Elasticsearch",
  "Docker",
  "Kubernetes",
  "AWS",
  "Alibaba Cloud",
  "Terraform",
  "Helm",
  "ArgoCD",
];

const projectIcons: Record<string, string> = {
  Homelab: "ri-home-5-line",
  "paperless-py": "ri-file-search-line",
  reciprocus: "ri-bit-coin-line",
  chirper: "ri-twitter-x-line",
  default: "ri-code-line",
};
---

<Layout>
  <!-- ABOUT + CONTACT -->
  <section
    id="about"
    class="container"
    style="padding-top: var(--space-section); padding-bottom: 1rem;"
  >
    <p style="max-width: 520px;">
      I build AI-powered systems for finance — semantic search over 100k
      instruments in 300ms, RAG pipelines that stream LLM commentary onto
      financial reports, and quantitative data platforms processing millions of
      messages daily. Currently at Premialab shipping AI-driven analytics to
      tier-one banks.
    </p>
  </section>

  <div class="container" style="padding-bottom: var(--space-section);">
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <span class="btn-wrap">
        <a
          href="mailto:faiman.rahyaz@gmail.com"
          class="btn"
          id="email-btn"
          style="display: inline-flex; align-items: center; gap: 6px;"
          ><i class="ri-mail-line" style="font-size:14px"></i>Email</a
        >
        <span class="btn-copy-tip" id="email-tip">Copy</span>
      </span>
      <a
        href="https://github.com/viscory"
        class="btn"
        style="display: inline-flex; align-items: center; gap: 6px;"
        target="_blank"
        rel="noopener"
        ><i class="ri-github-line" style="font-size:14px"></i>GitHub</a
      >
      <a
        href="https://linkedin.com/in/faiyazr"
        class="btn"
        style="display: inline-flex; align-items: center; gap: 6px;"
        target="_blank"
        rel="noopener"
        ><i class="ri-linkedin-line" style="font-size:14px"></i>LinkedIn</a
      >
      <a
        href="/assets/resume.pdf"
        class="btn"
        style="display: inline-flex; align-items: center; gap: 6px;"
        target="_blank"
        rel="noopener"
        ><i class="ri-file-text-line" style="font-size:14px"></i>Resume</a
      >
    </div>
  </div>

  <hr class="container section-divider" />

  <!-- EXPERIENCE -->
  <section
    id="experience"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Experience</h2>
    <div class="bordered" style="border-top: none;">
      {
        renderedExperience.map(({ entry, Content }) => (
          <div class="bordered-bottom" style="padding: 1.25rem 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.25rem;">
              <h3 class="exp-company">
                {entry.data.url ? (
                  <a href={entry.data.url} target="_blank" rel="noopener">
                    {entry.data.company}
                  </a>
                ) : (
                  entry.data.company
                )}
              </h3>
              <span class="meta">
                {entry.data.startDate} &ndash; {entry.data.endDate}
              </span>
            </div>
            <span class="meta" style="display: block; margin-bottom: 0.75rem;">
              {entry.data.role} &middot; {entry.data.location}
            </span>
            <div class="exp-list">
              <Content />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- SKILLS -->
  <section
    id="skills"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Skills</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {skills.map((skill) => <span class="skill-tag">{skill}</span>)}
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- PROJECTS -->
  <section
    id="projects"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Projects</h2>
    <div class="bordered" style="border-top: none;">
      {
        renderedProjects.map(({ entry, Content }, i) => {
          const icon = projectIcons[entry.data.title] || projectIcons.default;
          return (
            <div
              class={i < renderedProjects.length - 1 ? "bordered-bottom" : ""}
              style="padding: 1.25rem 1rem;"
            >
              <div style="display: flex; gap: 1rem; align-items: flex-start;">
                <i
                  class={icon}
                  style="font-size:28px;flex-shrink:0;opacity:.6;line-height:1"
                />
                <div>
                  <h3>{entry.data.title}</h3>
                  <span
                    class="meta"
                    style="display: block; margin: 0.25rem 0 0.75rem;"
                  >
                    {entry.data.startYear}
                    {entry.data.endYear ? ` – ${entry.data.endYear}` : ""}
                  </span>
                  <Content />
                  <a href={entry.data.url} target="_blank" rel="noopener">
                    GitHub
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- EDUCATION -->
  <section
    id="education"
    class="container section-block"
    style="padding-top: var(--space-section);"
  >
    <h2 class="meta" style="margin-bottom: 1.5rem;">Education</h2>
    <div
      class="bordered"
      style="padding: 1.5rem 1.25rem; display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap;"
    >
      <img
        src="/assets/cuhk-logo.png"
        alt="CUHK"
        width="80"
        style="filter: grayscale(1); flex-shrink: 0;"
      />
      <div>
        <h3>The Chinese University of Hong Kong</h3>
        <p>B.Sc. in Computer Science</p>
        <div style="margin-top: 0.5rem;">
          <span class="meta" style="display: block;"
            >Concentration: Database and Information Systems</span
          >
          <span class="meta" style="display: block;"
            >Full Ride Admission Scholarship &middot; The 'Sunny' Award</span
          >
          <span class="meta" style="display: block;"
            >English Debating Team &middot; Google Developers Student Club</span
          >
        </div>
      </div>
    </div>
  </section>

  <div style="height: 4rem;"></div>
</Layout>
