---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const experience = await getCollection('experience');
const skills = ['TypeScript','Python','Java','Scala','Kotlin','Go','SQL','Vue.js','React','Nest.js','Spring','Ktor','Flask','FastAPI','AWS','Alibaba Cloud','Docker','Kubernetes','ArgoCD','Kafka','PostgreSQL','MongoDB','Redis','Elasticsearch','Terraform','Helm','AWS Bedrock','RAG','Vector DBs','GitOps','CI/CD','Microservices','Event-Driven','CQRS'];
---

<Layout>

  <!-- HERO -->
  <section id="hero" class="container" style="padding: var(--space-section) 24px;">
    <div style="max-width: 480px;">
      <img src="/assets/headshot.jpg" alt="" width="80" height="80" style="border-radius: 50%; border: 1px solid var(--color-fg); filter: grayscale(1); margin-bottom: 2rem;" />
      <h1>Faiyaz<br />Rahman</h1>
      <p style="margin: 1.5rem 0 2rem; max-width: 420px;">
        Full-stack developer building systems across AI, infrastructure, and product.
      </p>
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a href="mailto:faiman.rahyaz@gmail.com" class="btn">Email</a>
        <a href="https://github.com/viscory" class="btn" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/faiyazr" class="btn" target="_blank" rel="noopener">LinkedIn</a>
        <a href="/assets/resume.pdf" class="btn" target="_blank" rel="noopener">Resume</a>
      </div>
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- ABOUT -->
  <section id="about" class="container section-block">
    <span class="meta" style="display: block; margin-bottom: 1.5rem;">About</span>
    <p>
      Full-stack developer with 5+ years delivering systems across AI, infrastructure, and product. Architected multi-cloud fintech platforms, scaled Kafka to 1.5M+ messages/day, built Bedrock/RAG pipelines for quantitative reporting. Comfortable in TypeScript APIs, Vue/React UIs, and the GitOps glue between them.
    </p>
  </section>

  <hr class="container section-divider" />

  <!-- EXPERIENCE -->
  <section id="experience" class="container section-block">
    <span class="meta" style="display: block; margin-bottom: 1.5rem;">Experience</span>
    <div class="bordered" style="border-top: none;">
      {experience.map((entry) => (
        <div class="bordered-bottom" style="padding: 1.25rem 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.25rem;">
            <h3>{entry.data.company}</h3>
            <span class="meta">{entry.data.startDate} &ndash; {entry.data.endDate}</span>
          </div>
          <span class="meta" style="display: block; margin-bottom: 0.75rem;">{entry.data.role} &middot; {entry.data.location}</span>
          <ul style="list-style: none; padding: 0;">
            {entry.body.split('\n').filter(l => l.trim().startsWith('-')).map((line) => (
              <li style="padding: 0.2rem 0; text-indent: -1.1rem; padding-left: 1.1rem;">&mdash;&nbsp;{line.trim().replace(/^-\s*/, '')}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- SKILLS -->
  <section id="skills" class="container section-block">
    <span class="meta" style="display: block; margin-bottom: 1.5rem;">Skills</span>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {skills.map((skill) => (
        <span class="btn" style="padding: 0.3em 0.8em; font-size: var(--text-meta); text-transform: uppercase;">{skill}</span>
      ))}
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- PROJECTS -->
  <section id="projects" class="container section-block">
    <span class="meta" style="display: block; margin-bottom: 1.5rem;">Projects</span>
    <div class="bordered" style="border-top: none;">
      {projects.map((project, i) => (
        <div class={i < projects.length - 1 ? 'bordered-bottom' : ''} style="padding: 1.25rem 1rem;">
          <h3>{project.data.title}</h3>
          <span class="meta" style="display: block; margin: 0.25rem 0 0.75rem;">
            {project.data.startYear}{project.data.endYear ? ` \u2013 ${project.data.endYear}` : ''}
          </span>
          <p style="margin-bottom: 0.75rem;">{project.body}</p>
          <a href={project.data.url} target="_blank" rel="noopener">GitHub</a>
        </div>
      ))}
    </div>
  </section>

  <hr class="container section-divider" />

  <!-- EDUCATION -->
  <section id="education" class="container section-block">
    <span class="meta" style="display: block; margin-bottom: 1.5rem;">Education</span>
    <div class="bordered" style="padding: 1.5rem 1.25rem; display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap;">
      <img src="/assets/school-logo-1x.png" alt="CUHK" width="80" style="filter: grayscale(1); border: 1px solid var(--color-fg); flex-shrink: 0;" />
      <div>
        <h3>The Chinese University of Hong Kong</h3>
        <p>B.Sc. in Computer Science &middot; Second Class Honours (2:1) &middot; Sep 2018 &ndash; Jun 2023</p>
        <div style="margin-top: 0.5rem;">
          <span class="meta" style="display: block;">Concentration: Database and Information Systems</span>
          <span class="meta" style="display: block;">Full Ride Admission Scholarship &middot; The 'Sunny' Award</span>
          <span class="meta" style="display: block;">English Debating Team &middot; Google Developers Student Club</span>
        </div>
      </div>
    </div>
  </section>

  <div style="height: 3rem;"></div>

</Layout>
