#!/bin/sh
cd "$(dirname "$0")/.." || exit 1
BUN="mise exec bun@1.3.14 --"

echo "=== Pre-commit ==="
errors=0

echo "→ Building…"
$BUN bun run build 2>/dev/null || { echo "  ✗ Build failed"; errors=$((errors+1)); }

echo "→ Validating…"
$BUN bash scripts/validate.sh 2>/dev/null || { echo "  ✗ Validation failed"; errors=$((errors+1)); }

echo "→ CHANGELOG…"
if git diff --cached --exit-code CHANGELOG.md >/dev/null 2>&1; then
  if git diff --exit-code CHANGELOG.md >/dev/null 2>&1; then
    echo "  ✗ CHANGELOG.md not staged"
  else
    echo "  ✗ CHANGELOG.md has unstaged changes — git add CHANGELOG.md"
  fi
  errors=$((errors+1))
else
  echo "  ✓ staged"
fi

DEL=$(git diff --cached --unified=0 CHANGELOG.md 2>/dev/null | grep '^-[^-]')
if [ -n "$DEL" ]; then
  echo "  ✗ CHANGELOG.md has deletions (append-only)"
  errors=$((errors+1))
fi

if [ "$errors" -gt 0 ]; then echo "❌ Aborted ($errors)"; exit 1; fi
echo "✅ OK"
