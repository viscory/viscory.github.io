#!/bin/sh
cd "$(dirname "$0")/.." || exit 1
mise install 2>/dev/null || true

echo "=== Pre-commit ==="; errors=0

echo "→ Lint CSS…"
mise exec -- pnpm run lint:css || { echo "  ✗ Stylelint failed"; errors=$((errors+1)); }

echo "→ Format check…"
mise exec -- pnpm run format || { echo "  ✗ Prettier check failed (run pnpm run format:fix)"; errors=$((errors+1)); }

echo "→ Building…"
mise exec -- pnpm run build || { echo "  ✗ Build failed"; errors=$((errors+1)); }

echo "→ CHANGELOG…"
if git diff --cached --exit-code CHANGELOG.md >/dev/null 2>&1; then
  if git diff --exit-code CHANGELOG.md >/dev/null 2>&1; then echo "  ✗ CHANGELOG.md not staged"
  else echo "  ✗ CHANGELOG.md has unstaged changes"; fi
  errors=$((errors+1))
else echo "  ✓ staged"; fi

DEL=$(git diff --cached --unified=0 CHANGELOG.md | grep '^-[^-]')
[ -n "$DEL" ] && { echo "  ✗ CHANGELOG.md has deletions"; errors=$((errors+1)); }

[ "$errors" -gt 0 ] && { echo "❌ Aborted ($errors)"; exit 1; }
echo "✅ OK"
