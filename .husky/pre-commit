#!/bin/sh
cd "$(dirname "$0")/.." || exit 1
BUN="mise exec bun@1.3.14 --"

echo "=== Pre-commit Checks ==="
errors=0

# 1. Build
echo "→ Building…"
$BUN bun run build 2>/dev/null || { echo "  ✗ Build failed"; errors=$((errors+1)); }

# 2. Validate output
echo "→ Validating…"
$BUN bash scripts/validate.sh 2>/dev/null || { echo "  ✗ Validation failed"; errors=$((errors+1)); }

# 3. CHANGELOG must be staged
echo "→ Checking CHANGELOG…"
if git diff --cached --exit-code CHANGELOG.md >/dev/null 2>&1; then
  # No staged changes
  if git diff --exit-code CHANGELOG.md >/dev/null 2>&1; then
    echo "  ✗ CHANGELOG.md not staged — add an entry and stage it"
  else
    echo "  ✗ CHANGELOG.md has unstaged changes — stage with: git add CHANGELOG.md"
  fi
  errors=$((errors+1))
else
  echo "  ✓ CHANGELOG.md is staged"
fi

# 4. CHANGELOG must be append-only (no deletions)
DELETIONS=$(git diff --cached --unified=0 CHANGELOG.md 2>/dev/null | grep '^-[^-]' | head -5)
if [ -n "$DELETIONS" ]; then
  echo "  ✗ CHANGELOG.md has deletions — append-only policy"
  echo "$DELETIONS"
  errors=$((errors+1))
fi

if [ "$errors" -gt 0 ]; then
  echo "❌ $errors check(s) failed — commit aborted"
  exit 1
fi
echo "✅ All checks passed"
